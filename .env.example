# Server
PORT=3000
HOST=0.0.0.0

# Where to email new order notifications. If unset, orders are saved to orders.json only.
NOTIFY_EMAIL=info@droztukas.lt

# SMTP — leave blank to disable email. Tested with any standard SMTP provider
# (Mailgun, Postmark, SendGrid, your own postfix, Gmail with app password, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Drožtukas <no-reply@droztukas.lt>"

# Admin dashboard (/admin)
# Generate hash: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'mypassword'
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=
# Generate secret: openssl rand -hex 32
SESSION_SECRET=
# true behind HTTPS (production via Nginx), false for plain http://localhost dev
COOKIE_SECURE=true
